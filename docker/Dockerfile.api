FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /app
COPY pom.xml .
COPY pdf-engine/pom.xml pdf-engine/
COPY pdf-api/pom.xml pdf-api/
RUN mvn dependency:go-offline -B
COPY pdf-engine/src pdf-engine/src
COPY pdf-api/src pdf-api/src
RUN mvn package -DskipTests -B

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /app/pdf-api/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
